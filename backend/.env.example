# ==============================================================================
# MOOD LAYER BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
# ==============================================================================
# SECURITY ARCHITECTURE
# ==============================================================================
#
# This application uses a layered security approach:
#
# LAYER 1: Supabase Edge Function Secrets (Most Secure)
# -----------------------------------------------------
# Store these in Supabase Dashboard -> Edge Functions -> Secrets:
#   - SUPABASE_SERVICE_ROLE_KEY  (for Edge Function database access)
#   - OPENAI_API_KEY             (for embeddings and AI)
#   - ANTHROPIC_API_KEY          (for Claude AI)
#   - PINECONE_API_KEY           (for vector search)
#   - PINECONE_INDEX_HOST        (Pinecone index URL)
#   - API_SECRET                 (authenticates backend -> Edge Function)
#
# LAYER 2: Hosting Platform Env Vars (Production)
# -----------------------------------------------
# For Vercel/Railway/etc., set these in the platform's dashboard:
#   - SUPABASE_URL
#   - SUPABASE_KEY               (service role - backend only!)
#   - SECURE_API_URL
#   - API_SECRET
#   - NODE_ENV=production
#
# LAYER 3: Local .env File (Development Only)
# -------------------------------------------
# This file - only for local development, gitignored.
#
# ==============================================================================

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key - BACKEND ONLY, NEVER EXPOSE TO FRONTEND
# Find in: Supabase Dashboard -> Settings -> API -> service_role key
# WARNING: This key bypasses Row Level Security!
SUPABASE_KEY=your_service_role_key_here

# ==============================================================================
# SECURE API CONFIGURATION
# ==============================================================================

# Edge Function URL for secure API operations
SECURE_API_URL=https://your-project.supabase.co/functions/v1/secure-api

# API Secret - MUST match the secret in Supabase Edge Function secrets
# Generate with: openssl rand -base64 32
API_SECRET=your_api_secret_here

# ==============================================================================
# PINECONE CONFIGURATION
# ==============================================================================

# Index name only - API key goes in Supabase Edge Function secrets
PINECONE_INDEX_NAME=your-index-name

# ==============================================================================
# DATABASE CONNECTION (DEVELOPMENT/MIGRATIONS ONLY)
# ==============================================================================
#
# WARNING: Direct database access bypasses ALL Row Level Security!
#
# Options:
# 1. Direct connection (IPv6 only):
#    DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
#
# 2. Connection Pooler (IPv4 compatible - recommended):
#    DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# Find pooler connection string in:
# Supabase Dashboard -> Settings -> Database -> Connection string -> Session pooler
#
# IMPORTANT: URL-encode special characters in password:
#   & -> %26
#   = -> %3D
#   / -> %2F
#   + -> %2B

# DATABASE_URL=postgresql://postgres.your-project:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ==============================================================================
# PLATFORM INTEGRATION CREDENTIALS (Optional)
# ==============================================================================

# Shopify App Credentials (from Shopify Partner Dashboard)
# SHOPIFY_API_KEY=your_shopify_api_key
# SHOPIFY_SECRET=your_shopify_api_secret
# SHOPIFY_API_VERSION=2024-01
# SHOPIFY_SCOPES=read_products,read_product_listings,read_inventory

# Token encryption key - generate with: openssl rand -hex 32
# SHOPIFY_TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# WooCommerce Credentials (generated per-store)
# WOO_CLIENT_ID=
# WOO_CLIENT_SECRET=

# App URL for OAuth callbacks (your Vercel deployment URL)
# APP_URL=https://backend-tml.vercel.app

# ==============================================================================
# CDN / IMAGE STORAGE CONFIGURATION (Optional)
# ==============================================================================

# CDN Provider: cloudflare-r2 | s3 | vercel-blob
# CDN_PROVIDER=cloudflare-r2

# Storage bucket name
# CDN_BUCKET=moodlayer-images

# Public CDN URL (for serving images)
# CDN_PUBLIC_URL=https://images.yourdomain.com

# Cloudflare R2 Configuration
# CLOUDFLARE_ACCOUNT_ID=

# S3-compatible credentials (works with R2 and S3)
# CDN_ACCESS_KEY_ID=
# CDN_SECRET_ACCESS_KEY=
# CDN_REGION=auto

# ==============================================================================
# NOTION INTEGRATION (Optional)
# ==============================================================================

# Notion API key for task/project management integration
# Get from: https://www.notion.so/my-integrations
# NOTION_API_KEY=

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================

# Comma-separated list of allowed origins for CORS
# In production, set to your frontend domains only
# ALLOWED_ORIGINS=https://app.moodlayer.com,https://www.moodlayer.com

# ==============================================================================
# RATE LIMITING
# ==============================================================================

# Max requests per minute per IP (default: 60)
# RATE_LIMIT_MAX=60

# ==============================================================================
# AI API KEYS (Required for Photo Upload & Product Extraction)
# ==============================================================================

# Anthropic Claude API - Used for product enrichment (tags, colors, descriptions)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override default enrichment model (defaults to claude-3-5-sonnet-20241022)
# ENRICHMENT_MODEL=claude-3-5-sonnet-20241022

# Google Gemini API - Used for multi-product detection in images
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override Gemini vision model (defaults to gemini-2.0-flash-exp)
# GEMINI_VISION_MODEL=gemini-2.0-flash-exp

# OpenAI API - Used for background removal (gpt-image-1 model)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ==============================================================================
# IMAGE PROCESSING SETTINGS
# ==============================================================================

# Set to 'true' to return mock data instead of real AI processing
# Default: false (real processing enabled)
# DEMO_MODE=false

# Set to 'false' to disable background removal/processing
# Default: true (processing enabled)
# PROCESSING_ENABLED=true

# ==============================================================================
# ENVIRONMENT
# ==============================================================================

# Set to 'production' in production environments
# NODE_ENV=development
