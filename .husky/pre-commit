#!/bin/sh

# Alate Pre-commit Hook
# Runs checks before allowing commit

echo "🔍 Running pre-commit checks..."

# 0a. Self-check: Validate pre-commit hook syntax (Husky v10 compatibility)
# Check for deprecated shebang at line 1 specifically
if head -n 1 .husky/pre-commit | grep -q "#!/usr/bin/env sh"; then
  echo "❌ DEPRECATED Husky syntax: #!/usr/bin/env sh"
  echo "   Replace line 1 with: #!/bin/sh"
  exit 1
fi
# Check for deprecated husky.sh sourcing in first 5 lines
if head -n 5 .husky/pre-commit | grep -q "_/husky.sh"; then
  echo "❌ DEPRECATED Husky syntax: husky.sh sourcing"
  echo "   Remove line: . \"\$(dirname -- \"\$0\")/_/husky.sh\""
  exit 1
fi

# 0b. CRITICAL: Prevent direct commits to main/master
echo "\n🚫 Checking branch..."
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "master" ] || [ "$BRANCH" = "main" ]; then
  echo "❌ Cannot commit directly to $BRANCH"
  echo "   Create a feature branch instead:"
  echo "   git checkout -b feature/your-feature-name"
  exit 1
fi
echo "✅ Branch check passed (on $BRANCH)"

# 1. Check for TypeScript errors (BLOCKING) - backend and mobile only
echo "\n📘 Checking TypeScript..."

cd backend && npx tsc --noEmit
BACKEND_TS_EXIT=$?
cd ..

cd mobile && npx tsc --noEmit
MOBILE_TS_EXIT=$?
cd ..

if [ $BACKEND_TS_EXIT -ne 0 ] || [ $MOBILE_TS_EXIT -ne 0 ]; then
  echo "❌ TypeScript errors found. Please fix before committing."
  exit 1
fi

echo "✅ TypeScript check passed"

# 2. SECURITY: Check for secrets/API keys
echo "\n🔐 Checking for secrets..."
if git diff --cached | grep -iE "(SUPABASE_SERVICE_ROLE_KEY|ANTHROPIC_API_KEY|OPENAI_API_KEY|sk-[a-zA-Z0-9]{40,}|-----BEGIN.*PRIVATE KEY-----)" | grep -v ".md:" | grep -v "# Example:"; then
  echo "\n❌ SECURITY: API key or secret detected in commit"
  echo "   Never commit secrets to the repository"
  echo "   Use environment variables instead"
  exit 1
fi
echo "✅ No secrets detected"

# 3. Check Vercel function limit (Hobby plan: 12 max)
echo "\n📦 Checking Vercel function limit..."
FUNCTION_COUNT=$(ls backend/api/*.ts 2>/dev/null | wc -l)
if [ $FUNCTION_COUNT -gt 12 ]; then
  echo "❌ Vercel function limit exceeded: $FUNCTION_COUNT/12"
  echo "   Hobby plan allows max 12 serverless functions"
  echo "   Consolidate endpoints or upgrade plan"
  exit 1
fi
echo "✅ Function count OK ($FUNCTION_COUNT/12)"

# 3b. CRITICAL PATTERNS: Backend safety checks
echo "\n🛡️  Checking critical backend patterns..."

# Check timeout exists in secureAI
if [ -f "backend/sdk/shared/secureAI.ts" ]; then
  if ! grep -q "AbortController" backend/sdk/shared/secureAI.ts; then
    echo "❌ AbortController timeout removed from secureAI.ts!"
    echo "   This is required to prevent hanging requests"
    exit 1
  fi
fi

# Check Anthropic fallback exists
if [ -f "backend/sdk/shared/secureAI.ts" ]; then
  if ! grep -q "callAnthropicDirect" backend/sdk/shared/secureAI.ts; then
    echo "❌ Anthropic direct API fallback removed from secureAI.ts!"
    exit 1
  fi
fi

echo "✅ Critical pattern checks passed"

# 4. Check for large files (>500KB)
echo "\n📏 Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only | xargs ls -l 2>/dev/null | awk '$5 > 512000 {print $9}')
if [ -n "$LARGE_FILES" ]; then
  echo "❌ Large files detected (>500KB):"
  echo "$LARGE_FILES"
  echo "\n   Consider:"
  echo "   (1) Compress images/assets"
  echo "   (2) Use CDN for large files"
  echo "   (3) Add to .gitignore if build artifact"
  exit 1
fi
echo "✅ No large files detected"

# 5. Check for 'any' types in modified files
echo "\n🔎 Checking for 'any' types in staged files..."
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
  ANY_COUNT=0
  for FILE in $STAGED_TS_FILES; do
    if grep -q ": any" "$FILE" || grep -q "as any" "$FILE"; then
      echo "⚠️  Found 'any' type in: $FILE"
      ANY_COUNT=$((ANY_COUNT + 1))
    fi
  done

  if [ $ANY_COUNT -gt 0 ]; then
    echo "\n⚠️  Warning: Found $ANY_COUNT file(s) with 'any' types."
    echo "Consider adding proper types before committing."
    echo "To commit anyway, use: git commit --no-verify"
    # Don't fail, just warn
  fi
fi

# 6. Check for logging in new backend endpoints (WARNING)
echo "\n📝 Checking logging in new API endpoints..."
NEW_API_FILES=$(git diff --cached --name-only --diff-filter=A | grep "^backend/api/.*\.ts$" || true)
MISSING_LOG_COUNT=0
if [ -n "$NEW_API_FILES" ]; then
  for FILE in $NEW_API_FILES; do
    if ! grep -q "console\.log.*Request received\|console\.error" "$FILE" 2>/dev/null; then
      echo "⚠️  New endpoint lacks logging: $FILE"
      echo "   Add: console.log('[endpoint-name] Request received', { ... })"
      MISSING_LOG_COUNT=$((MISSING_LOG_COUNT + 1))
    fi
  done

  if [ $MISSING_LOG_COUNT -gt 0 ]; then
    echo "\n⚠️  WARNING: $MISSING_LOG_COUNT endpoint(s) missing logging"
    echo "   See CLAUDE.md 'Logging & Monitoring' section"
    # Don't exit - just warn
  fi
fi

# 7. Check for WIP markers (WARNING)
echo "\n🚧 Checking for work-in-progress markers..."
if git diff --cached | grep -E "FIXME|XXX|HACK|WIP|TEMP" | grep -v ".md:"; then
  echo "\n⚠️  WARNING: Work-in-progress markers found"
  echo "   Clean up FIXME/XXX/HACK/WIP/TEMP before committing or add explanation"
  # Don't exit - just warn
fi

# 8. Check for console.log in production code (excluding explicitly allowed patterns)
echo "\n🔍 Checking for console.log statements..."
if echo "$STAGED_TS_FILES" | xargs grep -n "console\.log" 2>/dev/null | grep -v "// OK: console.log" | grep -v "logger.ts"; then
  echo "\n⚠️  Warning: Found console.log statements. Consider using proper logging."
  echo "Add '// OK: console.log' comment to explicitly allow, or use logger instead."
  # Don't fail, just warn
fi

# 9. Check for TODO without issue reference
echo "\n📝 Checking TODO comments..."
if echo "$STAGED_TS_FILES" | xargs grep -n "TODO:" 2>/dev/null | grep -v "TODO: \[" ; then
  echo "\n⚠️  Warning: Found TODO without reference tag."
  echo "Use format: TODO: [TAG-NAME] Description"
  # Don't fail, just warn
fi

echo "\n✅ All pre-commit checks passed!"
echo "🚀 Ready to commit\n"
